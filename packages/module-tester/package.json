{
  "name": "@zerobias-org/module-tester",
  "description": "Test harness for Hub modules - enables REST-level testing on Docker containers",
  "version": "1.0.9",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "scripts": {
    "clean": "rm -rf dist/",
    "transpile": "tsc -b",
    "build": "npm run transpile",
    "test": "npm run test:unit",
    "test:unit": "node --import tsx/esm ../../node_modules/mocha/bin/mocha.js --exit --extensions ts --inline-diffs --reporter=list test/unit/**/*.ts",
    "test:watch": "npm run test -- --watch --reporter=min",
    "lint": "eslint src/",
    "lint:fix": "eslint --fix src/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/zerobias-org/util.git",
    "directory": "packages/module-tester"
  },
  "author": "team@zerobias.com",
  "license": "UNLICENSED",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/"
  },
  "files": [
    "dist",
    "templates"
  ],
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "axios": "^1.13.5",
    "dockerode": "^4.0.0",
    "get-port": "^7.1.0",
    "uuid": "^13.0.0",
    "yaml": "2.8.3"
  },
  "overrides": {
    "@zerobias-org/types-core-js": "$@zerobias-org/types-core-js",
    "diff": "^8.0.4",
    "glob": ">=11",
    "serialize-javascript": "7.0.5",
    "yaml": "2.8.3"
  }
}
