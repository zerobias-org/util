{
  "name": "@zerobias-org/zbb",
  "description": "ZeroBias Build — Gradle wrapper + slot-based environment management",
  "version": "0.2.0",
  "type": "module",
  "bin": {
    "zbb": "bin/zbb.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./lib/index.ts"
    },
    "./slot": {
      "types": "./dist/slot/index.d.ts",
      "default": "./lib/slot/index.ts"
    },
    "./env": {
      "types": "./dist/env/index.d.ts",
      "default": "./lib/env/index.ts"
    }
  },
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "node --experimental-strip-types --test lib/**/*.test.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/zerobias-org/util.git",
    "directory": "packages/zbb"
  },
  "author": "team@zerobias.com",
  "license": "UNLICENSED",
  "dependencies": {
    "js-yaml": "^4.1.0",
    "semver": "^7.6.0"
  },
  "devDependencies": {
    "@types/semver": "^7.7.1"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/"
  },
  "files": [
    "bin",
    "lib",
    "dist"
  ],
  "engines": {
    "node": ">=22.0.0"
  }
}
