{
  "name": "@zerobias-org/zbb",
  "description": "ZeroBias Build — Gradle wrapper + slot-based environment management.",
  "version": "0.3.50",
  "type": "module",
  "bin": {
    "zbb": "bin/zbb.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./slot": {
      "types": "./dist/slot/index.d.ts",
      "default": "./dist/slot/index.js"
    },
    "./env": {
      "types": "./dist/env/index.d.ts",
      "default": "./dist/env/index.js"
    },
    "./stack": {
      "types": "./dist/stack/index.d.ts",
      "default": "./dist/stack/index.js"
    }
  },
  "types": "dist/index.d.ts",
  "scripts": {
    "transpile": "tsc -b",
    "build": "npm run lint && npm run transpile",
    "lint": "eslint 'lib/**/*.ts' 'test/**/*.ts'",
    "lint:fix": "eslint --fix 'lib/**/*.ts' 'test/**/*.ts'",
    "test": "node --import tsx/esm --test test/*.test.ts test/**/*.test.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/zerobias-org/util.git",
    "directory": "packages/zbb"
  },
  "author": "team@zerobias.com",
  "license": "UNLICENSED",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/"
  },
  "files": [
    "bin",
    "lib",
    "dist",
    "stacks"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "jsonata": "^2.0.0",
    "semver": "^7.6.0",
    "yaml": "2.8.3"
  },
  "overrides": {
    "@zerobias-org/types-core-js": "$@zerobias-org/types-core-js",
    "diff": "^8.0.4",
    "glob": ">=11",
    "serialize-javascript": "7.0.5",
    "yaml": "2.8.3"
  }
}
