{
  "name": "@zerobias-org/util-secrets-manager",
  "version": "1.0.1",
  "description": "Secrets manager abstraction over AWS Secrets Manager, AWS SSM Parameter Store, HashiCorp Vault, Azure Key Vault, and local file/env backends",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "scripts": {
    "clean": "rimraf dist/ generated/",
    "generate": "hub-generator generate -g hub-module -i ./secrets-manager.yml -o generated/ --global-property models,supportingFiles=index.ts && rm -f ./generated/api/index.ts",
    "transpile": "tsc -b",
    "build": "npm run lint && npm run generate && npm run transpile",
    "test": "npm run test:unit",
    "test:unit": "CACHE_TIMEOUT_SECONDS=5 node --import tsx/esm ../../node_modules/mocha/bin/mocha.js --exit --extensions ts --inline-diffs --reporter=list test/unit/**/*.ts",
    "test:integration": "CACHE_TIMEOUT_SECONDS=5 node --import tsx/esm ../../node_modules/mocha/bin/mocha.js --exit --extensions ts --inline-diffs --reporter=list test/integration/**/*.ts",
    "lint": "eslint 'src/**/*.ts'",
    "lint:fix": "eslint --fix 'src/**/*.ts'"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "author": "team@zerobias.com",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git@github.com:zerobias-org/util.git",
    "directory": "packages/secrets-manager"
  },
  "publishConfig": {
    "registry": "https://pkg.zerobias.org/"
  },
  "files": [
    "dist/src",
    "dist/generated",
    "secrets-manager.yml",
    "*.md"
  ],
  "dependencies": {
    "@zerobias-org/logger": "^3.0.10",
    "@zerobias-org/util-codegen": "^2.0.56"
  }
}
