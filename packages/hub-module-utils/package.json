{
  "name": "@zerobias-org/util-hub-module-utils",
  "description": "Hub Module utils",
  "version": "2.0.41",
  "type": "module",
  "main": "dist/src/index.js",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    }
  },
  "scripts": {
    "clean": "rm -rf dist/ generated/",
    "transpile": "tsc -b",
    "build": "npm run lint && npm run generate && npm run transpile",
    "generate": "hub-generator generate -g hub-module -i test/unit/enum.yml -o generated/",
    "test": "npm run test:unit",
    "test:unit": "node --import tsx/esm ../../node_modules/mocha/bin/mocha.js --exit --extensions ts --inline-diffs --reporter=list test/unit/**/*.ts",
    "test:watch": "npm run test:generate && npm run test -- --watch --reporter=min",
    "lint": "eslint src/",
    "lint:fix": "eslint --fix src/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/zerobias-org/util.git",
    "directory": "hub-module-utils"
  },
  "author": "ctamas@zerobias.com",
  "license": "UNLICENSED",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/"
  },
  "files": [
    "dist",
    "bom.json"
  ],
  "dependencies": {
    "@zerobias-org/types-amazon-js": "^1.0.35",
    "@zerobias-org/types-core": "^1.0.22",
    "@zerobias-org/types-core-js": "^1.2.17",
    "@zerobias-org/types-microsoft-js": "^1.0.34",
    "@zerobias-org/util-codegen": "^2.0.46",
    "@zerobias-org/util-connector": "^1.0.37",
    "axios": "^1.13.5",
    "change-case": "^5.0.0",
    "jsonata": "^2.0.0",
    "qs": "^6.14.0"
  },
  "overrides": {
    "@zerobias-org/types-core-js": "$@zerobias-org/types-core-js",
    "diff": "^8.0.4",
    "glob": ">=11",
    "serialize-javascript": "7.0.5",
    "yaml": "2.8.3"
  }
}
