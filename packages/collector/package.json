{
  "name": "@zerobias-org/util-collector",
  "version": "1.0.37",
  "description": "Common utilities for collector bots - HTTP fetching, data chunking, CSV/YAML parsing",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js",
      "default": "./dist/src/index.js"
    }
  },
  "scripts": {
    "clean": "rm -rf dist/",
    "transpile": "tsc -b",
    "build": "npm run lint && npm run transpile",
    "lint": "eslint 'src/**/*.ts'",
    "lint:fix": "eslint --fix 'src/**/*.ts'",
    "test": "npm run test:unit",
    "test:unit": "node --import tsx/esm ../../node_modules/mocha/bin/mocha.js --exit --extensions ts --inline-diffs --reporter=list test/unit/**/*.ts",
    "test:watch": "npm run test -- --watch --reporter=min"
  },
  "files": [
    "dist/src",
    "CHANGELOG.md"
  ],
  "keywords": [
    "collector",
    "utils",
    "etl",
    "batch"
  ],
  "author": "ZeroBias <support@zerobias.com>",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/zerobias-org/util",
    "directory": "packages/collector"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/"
  },
  "dependencies": {
    "@zerobias-com/platform-sdk": "^1.1.5",
    "@zerobias-org/logger": "^3.0.6",
    "@zerobias-org/types-core-js": "^1.2.17",
    "@zerobias-org/util-connector": "^1.0.37",
    "axios": "^1.13.5",
    "csv-parse": "^6.0.0",
    "yaml": "2.8.3"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "overrides": {
    "@zerobias-org/types-core-js": "$@zerobias-org/types-core-js",
    "diff": "^8.0.4",
    "glob": ">=11",
    "serialize-javascript": "7.0.5",
    "yaml": "2.8.3"
  }
}
