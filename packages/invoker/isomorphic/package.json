{
  "name": "@zerobias-org/util-api-invoker-isomorphic",
  "version": "1.0.36",
  "description": "Isomorphic Api Invoker",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "scripts": {
    "clean": "rm -rf dist/",
    "transpile": "tsc -b",
    "test": "npm run test:unit",
    "test:unit": "node --import tsx/esm ../../../node_modules/mocha/bin/mocha.js --exit --extensions ts --inline-diffs --reporter=list test/unit/**/*.ts",
    "test:watch": "npm run test -- --watch --reporter=min",
    "lint": "eslint 'src/**/*.ts' 'test/**/*.ts'",
    "lint:fix": "eslint --fix 'src/**/*.ts' 'test/**/*.ts'",
    "build": "npm run lint && npm run transpile"
  },
  "author": "ZeroBias <support@zerobias.com>",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/zerobias-org/util.git",
    "directory": "packages/invoker/isomorphic"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@zerobias-org/types-core-js": "^1.2.17",
    "@zerobias-org/util-api-invoker-api": "^1.0.35",
    "axios": "^1.13.5",
    "form-data": "^4.0.0",
    "qs": "^6.14.0"
  },
  "overrides": {
    "@zerobias-org/types-core-js": "$@zerobias-org/types-core-js",
    "diff": "^8.0.4",
    "glob": ">=11",
    "serialize-javascript": "7.0.5",
    "yaml": "2.8.3"
  }
}
